---
import { ThemeToggle } from "@/components/ThemeToggle";
---

<header class="fixed inset-x-0 top-4 z-50 px-4">
  <div class="mx-auto max-w-3xl">
    <nav
      class="border-border/40 bg-background/70 shadow-primary/5 flex h-12 items-center justify-between rounded-2xl border px-4 shadow-lg backdrop-blur-xl"
    >
      <!-- Logo -->
      <a
        href="/"
        class="hover:text-primary font-mono text-base font-semibold tracking-tight transition-colors"
      >
        RayBlog
      </a>

      <!-- Desktop nav links -->
      <div class="hidden items-center gap-1 md:flex">
        <a
          href="/blog"
          class="text-muted-foreground hover:bg-muted hover:text-foreground rounded-lg px-3 py-1.5 text-sm transition-colors"
        >
          Blog
        </a>
        <a
          href="/blog/tags"
          class="text-muted-foreground hover:bg-muted hover:text-foreground rounded-lg px-3 py-1.5 text-sm transition-colors"
        >
          Tags
        </a>
      </div>

      <!-- Right side: theme toggle + mobile hamburger -->
      <div class="flex items-center gap-2">
        <ThemeToggle client:only="react" />

        <!-- Mobile hamburger -->
        <button
          id="mobile-menu-btn"
          aria-label="Toggle menu"
          class="text-muted-foreground hover:bg-muted hover:text-foreground relative flex size-9 items-center justify-center rounded-lg transition-colors md:hidden"
        >
          <svg
            id="icon-menu"
            xmlns="http://www.w3.org/2000/svg"
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="absolute transition-all duration-200"
          >
            <line x1="4" x2="20" y1="6" y2="6"></line>
            <line x1="4" x2="20" y1="12" y2="12"></line>
            <line x1="4" x2="20" y1="18" y2="18"></line>
          </svg>
          <svg
            id="icon-close"
            xmlns="http://www.w3.org/2000/svg"
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="absolute scale-75 opacity-0 transition-all duration-200"
          >
            <path d="M18 6 6 18"></path>
            <path d="m6 6 12 12"></path>
          </svg>
        </button>
      </div>
    </nav>

    <!-- Mobile dropdown menu (animation driven by #mobile-menu CSS in global.css) -->
    <div id="mobile-menu">
      <div>
        <div
          class="border-border/40 bg-background/80 shadow-primary/5 mt-2 rounded-2xl border p-2 shadow-lg backdrop-blur-xl"
        >
          <a
            href="/blog"
            class="text-muted-foreground hover:bg-muted hover:text-foreground block rounded-lg px-4 py-2.5 text-sm transition-colors"
          >
            Blog
          </a>
          <a
            href="/blog/tags"
            class="text-muted-foreground hover:bg-muted hover:text-foreground block rounded-lg px-4 py-2.5 text-sm transition-colors"
          >
            Tags
          </a>
        </div>
      </div>
    </div>
  </div>
</header>

<script>
  // mq listener is not DOM-dependent; register only once for the lifetime of the tab
  const mq = window.matchMedia("(min-width: 768px)");
  mq.addEventListener("change", (e) => {
    if (e.matches) closeMenuGlobal();
  });

  // closeMenuGlobal is used by the mq listener which outlives any single page load
  function closeMenuGlobal() {
    const menu = document.getElementById("mobile-menu");
    const iconMenu = document.getElementById("icon-menu");
    const iconClose = document.getElementById("icon-close");
    menu?.classList.remove("is-open");
    iconMenu?.classList.add("opacity-100", "scale-100");
    iconMenu?.classList.remove("opacity-0", "scale-75");
    iconClose?.classList.add("opacity-0", "scale-75");
    iconClose?.classList.remove("opacity-100", "scale-100");
  }

  // Re-initialize click listener after every navigation (astro:page-load fires on
  // initial load AND after each ClientRouter navigation)
  document.addEventListener("astro:page-load", () => {
    const btn = document.getElementById("mobile-menu-btn");
    const menu = document.getElementById("mobile-menu");
    const iconMenu = document.getElementById("icon-menu");
    const iconClose = document.getElementById("icon-close");

    if (!btn) return;

    let isOpen = false;

    function openMenu() {
      isOpen = true;
      menu?.classList.add("is-open");
      iconMenu?.classList.add("opacity-0", "scale-75");
      iconMenu?.classList.remove("opacity-100", "scale-100");
      iconClose?.classList.add("opacity-100", "scale-100");
      iconClose?.classList.remove("opacity-0", "scale-75");
    }

    function closeMenu() {
      isOpen = false;
      menu?.classList.remove("is-open");
      iconMenu?.classList.add("opacity-100", "scale-100");
      iconMenu?.classList.remove("opacity-0", "scale-75");
      iconClose?.classList.add("opacity-0", "scale-75");
      iconClose?.classList.remove("opacity-100", "scale-100");
    }

    btn.addEventListener("click", () => {
      if (isOpen) closeMenu();
      else openMenu();
    });
  });
</script>
