---
import type { CollectionEntry } from "astro:content";
import { Badge } from "@/components/ui/badge";

interface Props {
  post: CollectionEntry<"blog">;
  index?: number;
}

const { post, index = 0 } = Astro.props;
const { title, description, pubDate, tags, image } = post.data;

const formattedDate = pubDate.toLocaleDateString("en-US", {
  year: "numeric",
  month: "short",
  day: "numeric",
});

// Rough read time estimate (average 200 wpm)
const wordCount = (post.body ?? "").split(/\s+/).length;
const readTime = Math.max(1, Math.round(wordCount / 200));
---

<a
  href={`/blog/${post.id}`}
  class="group border-border bg-card hover:border-foreground/20 flex h-full flex-col overflow-hidden rounded-xl border transition-all duration-200 hover:shadow-sm"
>
  <div class="relative aspect-video overflow-hidden">
    {
      import.meta.env.DEV && post.data.draft && (
        <span class="absolute top-2 left-2 z-10 rounded bg-amber-500/20 px-1.5 py-0.5 font-mono text-[10px] font-bold tracking-wider text-amber-400 uppercase">
          draft
        </span>
      )
    }
    {
      image ? (
        <img
          src={image}
          alt={title}
          class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
        />
      ) : (
        <div class="bg-muted relative h-full w-full">
          {/* Dot grid pattern */}
          <div class="absolute inset-0 opacity-40">
            <svg width="100%" height="100%" xmlns="http://www.w3.org/2000/svg">
              <defs>
                <pattern
                  id={`dot-${index}`}
                  width="20"
                  height="20"
                  patternUnits="userSpaceOnUse"
                >
                  <circle
                    cx="1"
                    cy="1"
                    r="1"
                    fill="currentColor"
                    class="text-border"
                  />
                </pattern>
              </defs>
              <rect width="100%" height="100%" fill={`url(#dot-${index})`} />
            </svg>
          </div>
          <div class="absolute inset-0 flex items-center justify-center">
            <span class="text-foreground/8 font-mono text-6xl font-bold select-none">
              {title.charAt(0).toUpperCase()}
            </span>
          </div>
        </div>
      )
    }
  </div>

  <div class="flex flex-1 flex-col gap-2.5 p-4">
    {
      tags.length > 0 && (
        <div class="flex flex-wrap gap-1.5">
          {tags.map((tag) => (
            <Badge variant="outline" class="font-mono text-xs">
              #{tag}
            </Badge>
          ))}
        </div>
      )
    }

    <h3
      class="group-hover:text-primary line-clamp-2 text-sm leading-snug font-semibold tracking-tight transition-colors"
    >
      {title}
    </h3>

    {
      description && (
        <p class="text-muted-foreground line-clamp-2 text-xs leading-relaxed">
          {description}
        </p>
      )
    }

    <div class="mt-auto flex items-center justify-between pt-1">
      <time
        class="text-muted-foreground font-mono text-xs"
        datetime={pubDate.toISOString()}
      >
        {formattedDate}
      </time>
      <span class="text-muted-foreground font-mono text-xs">{readTime} min</span
      >
    </div>
  </div>
</a>
