---
import type { CollectionEntry } from "astro:content";
import { Badge } from "@/components/ui/badge";

interface Props {
  post: CollectionEntry<"blog">;
  index?: number;
}

const { post, index = 0 } = Astro.props;
const { title, description, pubDate, tags, image } = post.data;

// Deterministic gradient fallback based on index
const gradients = [
  "from-violet-700 via-violet-500 to-indigo-600",
  "from-indigo-600 via-violet-500 to-violet-700",
  "from-violet-600 via-indigo-500 to-violet-800",
  "from-violet-800 via-violet-500 to-indigo-600",
  "from-indigo-700 via-violet-500 to-violet-600",
];
const gradient = gradients[index % gradients.length];

const formattedDate = pubDate.toLocaleDateString("en-US", {
  year: "numeric",
  month: "short",
  day: "numeric",
});

// Rough read time estimate (average 200 wpm)
const wordCount = (post.body ?? "").split(/\s+/).length;
const readTime = Math.max(1, Math.round(wordCount / 200));
---

<a
  href={`/blog/${post.id}`}
  class="group border-border/60 bg-card hover:border-primary/30 hover:shadow-primary/10 flex flex-col overflow-hidden rounded-2xl border transition-all duration-300 hover:-translate-y-0.5 hover:shadow-lg"
>
  <div class="relative aspect-video overflow-hidden">
    {
      image ? (
        <img
          src={image}
          alt={title}
          class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
        />
      ) : (
        <div
          class={`h-full w-full bg-gradient-to-br ${gradient} opacity-80 transition-opacity duration-300 group-hover:opacity-100`}
        >
          <div class="absolute inset-0 opacity-20">
            <svg width="100%" height="100%" xmlns="http://www.w3.org/2000/svg">
              <defs>
                <pattern
                  id={`grid-${index}`}
                  width="32"
                  height="32"
                  patternUnits="userSpaceOnUse"
                >
                  <path
                    d="M 32 0 L 0 0 0 32"
                    fill="none"
                    stroke="white"
                    stroke-width="0.5"
                  />
                </pattern>
              </defs>
              <rect width="100%" height="100%" fill={`url(#grid-${index})`} />
            </svg>
          </div>
          <div class="absolute inset-0 flex items-center justify-center">
            <span class="font-mono text-5xl font-bold text-white/30 select-none">
              {title.charAt(0).toUpperCase()}
            </span>
          </div>
        </div>
      )
    }
    {
      image && (
        <div class="from-card/80 absolute inset-x-0 bottom-0 h-12 bg-gradient-to-t to-transparent" />
      )
    }
  </div>

  <div class="flex flex-1 flex-col gap-3 p-4">
    {
      tags.length > 0 && (
        <div class="flex flex-wrap gap-1.5">
          {tags.map((tag) => (
            <Badge variant="secondary" class="text-xs">
              #{tag}
            </Badge>
          ))}
        </div>
      )
    }

    <h3
      class="group-hover:text-primary line-clamp-2 text-base leading-snug font-semibold transition-colors"
    >
      {title}
    </h3>

    {
      description && (
        <p class="text-muted-foreground line-clamp-2 text-sm">{description}</p>
      )
    }

    <div class="mt-auto flex items-center justify-between pt-1">
      <time
        class="text-muted-foreground text-xs"
        datetime={pubDate.toISOString()}
      >
        {formattedDate}
      </time>
      <span class="text-muted-foreground text-xs">{readTime} min read</span>
    </div>
  </div>
</a>
