---
type CalloutType = "note" | "tip" | "warning" | "danger";

interface Props {
  type?: CalloutType;
  title?: string;
}

const { type = "note", title } = Astro.props;

const config: Record<
  CalloutType,
  { label: string; border: string; bg: string; icon: string; iconColor: string }
> = {
  note: {
    label: "Note",
    border: "border-indigo-400/60",
    bg: "bg-indigo-50/60 dark:bg-indigo-950/30",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>`,
    iconColor: "text-indigo-500",
  },
  tip: {
    label: "Tip",
    border: "border-emerald-400/60",
    bg: "bg-emerald-50/60 dark:bg-emerald-950/30",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a7 7 0 0 1 5 11.9V17a1 1 0 0 1-1 1H8a1 1 0 0 1-1-1v-3.1A7 7 0 0 1 12 2Z"/><path d="M9 21h6"/><path d="M12 17v4"/></svg>`,
    iconColor: "text-emerald-500",
  },
  warning: {
    label: "Warning",
    border: "border-amber-400/60",
    bg: "bg-amber-50/60 dark:bg-amber-950/30",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/><path d="M12 9v4"/><path d="M12 17h.01"/></svg>`,
    iconColor: "text-amber-500",
  },
  danger: {
    label: "Danger",
    border: "border-red-400/60",
    bg: "bg-red-50/60 dark:bg-red-950/30",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="m15 9-6 6"/><path d="m9 9 6 6"/></svg>`,
    iconColor: "text-red-500",
  },
};

const c = config[type];
---

<div
  class={`not-prose my-6 flex gap-3 rounded-xl border-l-4 px-4 py-3.5 ${c.border} ${c.bg}`}
>
  <span class={`mt-0.5 shrink-0 ${c.iconColor}`} set:html={c.icon} />
  <div class="min-w-0 flex-1">
    <p class="mb-1 text-sm font-semibold">
      {title ?? c.label}
    </p>
    <div class="text-muted-foreground prose-sm text-sm [&>p]:m-0">
      <slot />
    </div>
  </div>
</div>
