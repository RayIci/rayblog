---
interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: Heading[];
}

const { headings } = Astro.props;
const toc = headings.filter((h) => h.depth === 2 || h.depth === 3);
---

<nav
  class="not-prose border-border/50 mb-8 border-l-2 py-1 pl-4"
  aria-label="Table of contents"
>
  <p
    class="text-muted-foreground/60 mb-2.5 font-mono text-[10px] font-medium tracking-widest uppercase"
  >
    On this page
  </p>
  <ul class="space-y-1">
    {
      toc.map((h) => (
        <li class={h.depth === 3 ? "pl-3" : ""}>
          <a
            href={`#${h.slug}`}
            class="text-muted-foreground hover:text-foreground block text-xs leading-relaxed transition-colors"
          >
            {h.text}
          </a>
        </li>
      ))
    }
  </ul>
</nav>
