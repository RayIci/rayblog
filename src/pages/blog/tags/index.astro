---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { Badge } from "@/components/ui/badge";
import { getCollection } from "astro:content";
import { TAGS } from "@/lib/tags";

const posts = await getCollection("blog", ({ data }) => !data.draft);

const tagCounts = TAGS.map((tag) => ({
  tag,
  count: posts.filter((p) => p.data.tags.includes(tag)).length,
})).filter(({ count }) => count > 0);
---

<BaseLayout title="Tags" description="Browse posts by tag">
  <h1 class="mb-8 text-4xl font-bold">Tags</h1>
  <div class="flex flex-wrap gap-3">
    {
      tagCounts.map(({ tag, count }) => (
        <a href={`/blog/tags/${tag}`}>
          <Badge
            variant="outline"
            className="text-sm px-3 py-1 cursor-pointer hover:bg-accent transition-colors"
          >
            #{tag}
            <span class="text-muted-foreground ml-2">{count}</span>
          </Badge>
        </a>
      ))
    }
  </div>
  {tagCounts.length === 0 && <p class="text-muted-foreground">No tags yet.</p>}
</BaseLayout>
