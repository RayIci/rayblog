---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PostCard from "@/components/PostCard.astro";
import { getCollection } from "astro:content";
import { TAGS, type Tag } from "@/lib/tags";

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) =>
    import.meta.env.PROD ? !data.draft : true,
  );
  return TAGS.map((tag) => ({
    params: { tag },
    props: { posts: posts.filter((p) => p.data.tags.includes(tag)) },
  }));
}

const { tag } = Astro.params as { tag: Tag };
const { posts } = Astro.props;
const sorted = posts.sort(
  (a: (typeof posts)[number], b: (typeof posts)[number]) =>
    b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<BaseLayout title={`Tag: ${tag}`} description={`Posts tagged "${tag}"`}>
  <!-- Breadcrumb -->
  <div class="mb-6">
    <a
      href="/blog/tags"
      class="text-muted-foreground hover:text-primary flex w-fit items-center gap-1 text-sm transition-colors"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="14"
        height="14"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <path d="m15 18-6-6 6-6"></path>
      </svg>
      All tags
    </a>
  </div>

  <!-- Header -->
  <div class="mb-10">
    <h1 class="text-4xl font-bold tracking-tight">
      Posts tagged <span class="gradient-text">#{tag}</span>
    </h1>
    <p class="text-muted-foreground mt-2">
      {sorted.length} post{sorted.length !== 1 ? "s" : ""}
    </p>
  </div>

  <!-- Posts grid -->
  {
    sorted.length === 0 ? (
      <div class="text-muted-foreground py-24 text-center">
        <p class="font-mono text-sm">No posts yet.</p>
      </div>
    ) : (
      <div class="grid grid-cols-1 gap-5 md:grid-cols-2 lg:grid-cols-3">
        {sorted.map((post: (typeof posts)[number], i: number) => (
          <PostCard post={post} index={i} />
        ))}
      </div>
    )
  }
</BaseLayout>
