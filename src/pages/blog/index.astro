---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PostCard from "@/components/PostCard.astro";
import { getCollection } from "astro:content";
import { TAGS } from "@/lib/tags";

const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<BaseLayout title="Blog" description="All posts on RayBlog">
  <!-- Header -->
  <div class="mb-10">
    <h1 class="text-4xl font-bold tracking-tight">Blog</h1>
    <p class="text-muted-foreground mt-2 font-mono text-sm">
      {posts.length} post{posts.length !== 1 ? "s" : ""}
    </p>
  </div>

  <!-- Tag filter -->
  <div class="mb-8 flex flex-wrap gap-1.5">
    <a
      href="/blog"
      class="border-foreground/20 bg-foreground text-background rounded-lg border px-3 py-1 font-mono text-xs transition-colors"
    >
      all
    </a>
    {
      TAGS.map((tag) => (
        <a
          href={`/blog/tags/${tag}`}
          class="border-border text-muted-foreground hover:border-foreground/20 hover:text-foreground rounded-lg border px-3 py-1 font-mono text-xs transition-colors"
        >
          #{tag}
        </a>
      ))
    }
  </div>

  <!-- Posts grid with staggered entrance -->
  {
    posts.length > 0 ? (
      <div class="grid grid-cols-1 gap-4 md:grid-cols-2 lg:grid-cols-3">
        {posts.map((post, i) => (
          <div
            class="animate-fade-in-up h-full"
            style={`animation-delay: ${i * 60}ms`}
          >
            <PostCard post={post} index={i} />
          </div>
        ))}
      </div>
    ) : (
      <div class="text-muted-foreground py-24 text-center">
        <p class="font-mono text-sm">no posts yet.</p>
      </div>
    )
  }
</BaseLayout>
