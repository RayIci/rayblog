---
import BaseLayout from "@/layouts/BaseLayout.astro";
import {
  Card,
  CardContent,
  CardHeader,
  CardTitle,
  CardDescription,
} from "@/components/ui/card";
import { Badge } from "@/components/ui/badge";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<BaseLayout title="Blog" description="All posts on RayBlog">
  <h1 class="mb-8 text-4xl font-bold">Blog</h1>
  <div class="flex flex-col gap-4">
    {
      posts.map((post) => (
        <a href={`/blog/${post.id}`} class="group block">
          <Card className="transition-shadow group-hover:shadow-md">
            <CardHeader>
              <div class="flex items-start justify-between gap-4">
                <CardTitle className="group-hover:text-primary transition-colors">
                  {post.data.title}
                </CardTitle>
                <time class="text-muted-foreground shrink-0 text-sm">
                  {post.data.pubDate.toLocaleDateString("en-US", {
                    month: "short",
                    day: "numeric",
                    year: "numeric",
                  })}
                </time>
              </div>
              {post.data.description && (
                <CardDescription>{post.data.description}</CardDescription>
              )}
            </CardHeader>
            {post.data.tags.length > 0 && (
              <CardContent>
                <div class="flex flex-wrap gap-1">
                  {post.data.tags.map((tag) => (
                    <Badge variant="outline">{tag}</Badge>
                  ))}
                </div>
              </CardContent>
            )}
          </Card>
        </a>
      ))
    }
  </div>
</BaseLayout>
