---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { Card, CardContent, CardHeader, CardTitle, CardDescription } from "@/components/ui/card";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog", ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 5);
---

<BaseLayout title="Home">
  <!-- Hero -->
  <section class="py-16 text-center">
    <h1 class="text-5xl font-bold mb-4">RayBlog</h1>
    <p class="text-xl text-muted-foreground max-w-2xl mx-auto">
      A personal knowledge base — things I've learned, reference notes, and essays I keep coming back to.
    </p>
  </section>

  <!-- Recent Posts -->
  {
    posts.length > 0 && (
      <section>
        <h2 class="text-2xl font-semibold mb-6">Recent Posts</h2>
        <div class="flex flex-col gap-4">
          {posts.map((post) => (
            <a href={`/blog/${post.id}`} class="block group">
              <Card className="transition-shadow group-hover:shadow-md">
                <CardHeader>
                  <CardTitle className="group-hover:text-primary transition-colors">
                    {post.data.title}
                  </CardTitle>
                  {post.data.description && (
                    <CardDescription>{post.data.description}</CardDescription>
                  )}
                </CardHeader>
                <CardContent>
                  <time class="text-sm text-muted-foreground">
                    {post.data.pubDate.toLocaleDateString("en-US", {
                      year: "numeric",
                      month: "long",
                      day: "numeric",
                    })}
                  </time>
                </CardContent>
              </Card>
            </a>
          ))}
        </div>
        <div class="mt-8 text-center">
          <a href="/blog" class="text-sm text-primary hover:underline">
            View all posts →
          </a>
        </div>
      </section>
    )
  }
</BaseLayout>
