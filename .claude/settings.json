{
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "FILE=$(cat | jq -Rsr 'fromjson | .tool_input.file_path // empty' 2>/dev/null); [ -n \"$FILE\" ] && /home/alex/rayblog/node_modules/.bin/prettier --write \"$FILE\" 2>/dev/null || true"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd /home/alex/rayblog && /home/alex/.bun/bin/bun run lint 2>&1; exit 0"
          }
        ]
      }
    ]
  }
}
